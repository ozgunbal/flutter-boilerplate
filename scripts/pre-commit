#!/bin/bash

# Flutter Pre-commit Hook
# This script runs linting and formatting checks on staged Dart files

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_color() {
    echo -e "${1}${2}${NC}"
}

print_color $BLUE "🔍 Running Flutter pre-commit checks..."

# Get list of staged Dart files
STAGED_DART_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.dart$' || true)

if [ -z "$STAGED_DART_FILES" ]; then
    print_color $GREEN "✅ No Dart files to check. Proceeding with commit."
    exit 0
fi

print_color $YELLOW "📋 Staged Dart files:"
echo "$STAGED_DART_FILES" | sed 's/^/  - /'

# Temporary file to track if we need to re-add files
NEED_READD=false

# Function to check if flutter command exists
check_flutter() {
    if ! command -v flutter &> /dev/null; then
        print_color $RED "❌ Flutter command not found. Please install Flutter SDK."
        exit 1
    fi
}

# Function to run dart format on staged files
format_files() {
    print_color $YELLOW "🎨 Formatting Dart files..."
    
    for file in $STAGED_DART_FILES; do
        if [ -f "$file" ]; then
            print_color $BLUE "  Formatting: $file"
            dart format "$file"
            
            # Check if file was modified by formatter
            if ! git diff --quiet "$file"; then
                print_color $YELLOW "  ⚡ File was reformatted: $file"
                git add "$file"
                NEED_READD=true
            fi
        fi
    done
}

# Function to run dart fix on staged files
fix_files() {
    print_color $YELLOW "🔧 Running dart fix on staged files..."
    
    # Create a temporary file with staged file list
    TEMP_FILE=$(mktemp)
    echo "$STAGED_DART_FILES" > "$TEMP_FILE"
    
    while IFS= read -r file; do
        if [ -f "$file" ]; then
            print_color $BLUE "  Fixing: $file"
            dart fix --apply "$file" 2>/dev/null || true
            
            # Check if file was modified by fixer
            if ! git diff --quiet "$file"; then
                print_color $YELLOW "  ⚡ File was auto-fixed: $file"
                git add "$file"
                NEED_READD=true
            fi
        fi
    done < "$TEMP_FILE"
    
    rm "$TEMP_FILE"
}

# Function to run flutter analyze on staged files
analyze_files() {
    print_color $YELLOW "🔍 Running Flutter analyze..."
    
    # Run analyze on the entire project but focus on errors in staged files
    ANALYZE_OUTPUT=$(flutter analyze --no-preamble 2>&1 || true)
    
    if [ -n "$ANALYZE_OUTPUT" ]; then
        # Filter output to show only issues in staged files
        STAGED_ISSUES=""
        
        while IFS= read -r file; do
            if [ -f "$file" ]; then
                FILE_ISSUES=$(echo "$ANALYZE_OUTPUT" | grep "$file" || true)
                if [ -n "$FILE_ISSUES" ]; then
                    STAGED_ISSUES="$STAGED_ISSUES$FILE_ISSUES\n"
                fi
            fi
        done <<< "$STAGED_DART_FILES"
        
        if [ -n "$STAGED_ISSUES" ]; then
            print_color $RED "❌ Lint errors found in staged files:"
            echo -e "$STAGED_ISSUES"
            print_color $RED "\n💡 Please fix these issues before committing."
            print_color $YELLOW "   You can run 'dart fix --apply' to auto-fix some issues."
            exit 1
        fi
    fi
    
    print_color $GREEN "✅ No lint errors found in staged files."
}

# Function to check for generated files that might need building
check_generated_files() {
    # Check if any .dart files in staged files might need code generation
    NEEDS_GENERATION=$(echo "$STAGED_DART_FILES" | grep -E "(\.g\.dart|serializers\.dart|\.freezed\.dart)" || true)
    
    if [ -n "$NEEDS_GENERATION" ]; then
        print_color $YELLOW "🔄 Detected generated files. Checking if build_runner needs to run..."
        
        # Check if we're in the API client directory or main project
        if [ -f "lib/api/generated/pubspec.yaml" ]; then
            print_color $BLUE "  Running build_runner in API client..."
            cd lib/api/generated
            flutter packages pub run build_runner build --delete-conflicting-outputs > /dev/null 2>&1 || true
            cd ../../..
            
            # Re-add any modified generated files
            for file in $NEEDS_GENERATION; do
                if [ -f "$file" ] && ! git diff --quiet "$file"; then
                    print_color $YELLOW "  ⚡ Re-adding updated generated file: $file"
                    git add "$file"
                fi
            done
        fi
    fi
}

# Main execution
main() {
    check_flutter
    
    print_color $BLUE "🚀 Starting pre-commit checks for ${#STAGED_DART_FILES} Dart files..."
    
    # Step 1: Format files
    format_files
    
    # Step 2: Apply automatic fixes
    fix_files
    
    # Step 3: Check for generated files
    check_generated_files
    
    # Step 4: Run analysis
    analyze_files
    
    if [ "$NEED_READD" = true ]; then
        print_color $YELLOW "⚡ Some files were automatically formatted/fixed and re-added to staging."
    fi
    
    print_color $GREEN "✅ All pre-commit checks passed! Proceeding with commit."
}

# Run main function
main